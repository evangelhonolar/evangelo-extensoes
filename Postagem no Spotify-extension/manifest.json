{
  "manifest_version": 3,
  "name": "Postagem no Spotify",
  "version": "1.0.0",
  "description": "Automated interaction replay for Post at Spotify",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "identity",
    "debugger",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://www.googleapis.com/*"
  ],
  "oauth2": {
    "client_id": "278404481007-hlq36qbm6eunb8dqdsjov6874gj3gfp2.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/spreadsheets",
      "https://www.googleapis.com/auth/userinfo.profile",
      "https://www.googleapis.com/auth/userinfo.email"
    ]
  },
  "action": {
    "default_title": "Spotify Automation Panel",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}